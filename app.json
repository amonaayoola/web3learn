{
  "expo": {
    "name": "MAIDEN",
    "slug": "maiden",
    "version": "1.0.0",
    "scheme": "maiden",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maiden.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "package": "com.maiden.app"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ]
  }
}
